data/client/icons/*.png
data/client/icons/_missing_prefixes.py
data/client/icons/_extracted_files.json

# SWC 插件二进制 (Taro 自动下载)
packages/editor/.swc/


# Brainstorm visual companion (transient mockups)
.superpowers/

