dist/
*.js
*.d.ts
*.js.map
# (keep ts source; track only via tsc output dirs)
!*.config.js
# 保留 editor 的源码 global.d.ts
!packages/editor/types/global.d.ts

# Test / dump artifacts
coverage/
*.log

