{
  "name": "@lagrange/engine",
  "version": "0.1.0",
  "description": "纯逻辑战斗仿真引擎（平台无关）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
